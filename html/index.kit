<!DOCTYPE html>
<html lang="pl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=1">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap"
        rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@100..900&display=swap" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap"
        rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Dynalight&display=swap" rel="stylesheet">
    <title>Cut or Not</title>
    <link rel="stylesheet" href="../dist/css/main.min.css">
    <script src="https://kit.fontawesome.com/78533621b1.js" crossorigin="anonymous"></script>

</head>

<body>
    <!-- @include 'nav.kit' -->

    <header id="home">
        <div class="wrapper">
            <div class="hero">
                <div class="hero__bg">
                    <div class="hero__img">
                        <img src="../dist/img/heroImg.jpeg" alt="Zdjęcie właściceli salonu fryzjerskiego- Anny Dudek"
                            class="hero__img-main">
                        <i class="fa-solid fa-scissors hero__img-icon"></i>
                        <!-- <i class="fa-solid fa-scissors hero__img-icon-small"></i> -->
                        <img src="../dist/img/heroImgMid.jpeg" alt="Zdjęcie właściceli salonu fryzjerskiego- Anny Dudek"
                            class="hero__img-main-big">
                    </div>
                    <div class="hero__text-box">
                        <h1 class="hero__title">Anna <span>Dudek</span></h1>
                        <h2 class="hero__title-cd"> <span>Pracownia</span> Fryzjerska</h2>
                        <p class="hero__title-cd-name">Cut OR Not</p>
                        <p class="hero__text">Lorem ipsum dolor sit amet consectetur adipisicing elit. Accusantium
                            voluptatem, cupiditate eveniet consequatur unde enim, quo tempora repellat ullam aperiam
                            eligendi ipsam in aut ad esse sit dolore maiores quasi.
                        </p>
                        <div class="hero__button-box">
                            <div class="hero__button-box-one">
                                <button class="hero__button-box-one-aboutme"><span class="aboutme-span">Więcej o
                                        mnie</span></button>
                                <div class="hero__button-box-one-arrow"><i class="fa-solid fa-arrow-right"></i></div>
                            </div>
                            <div class="hero__button-box-two">
                                <a
                                    href="https://booksy.com/pl-pl/199021_cut-or-not-pracownia-fryzjerska-anna-dudek_fryzjer_10953_zaczernie#ba_s=seo"><button
                                        class="hero__button-box-two-signup"><span class="signup-span">Zarezerwuj
                                            termin</span> </button></a>


                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>






    <script src="../dist/js/main.min.js"></script>
</body>

</html>