    <header id="home">
        <!-- @include 'nav.kit' -->
    </header>

    <section class="hero-section">

        <div class="hero">
            <div class="hero__bg">


                <div class="hero__img">
                    <div class="text">
                        <button class="hero__img-btn"><i class="far fa-question-circle"></i></button>
                        <div class="text-cd">
                            <h2>Cześć, jestem Ania!</h2>
                            <p>Spełniłam swoje marzenie i otworzyłam własną pracownię fryzjerską CUT OR NOT. Jeśli
                                chcesz świetnie wyglądać, interesują Cię profesjonalne usługi, fryzjerstwo na wysokim
                                poziomie - serdecznie Cię zapraszam!
                            </p>
                        </div>
                    </div>
                    <img src="dist/img/heroImg.jpeg" alt="Zdjęcie właściceli salonu fryzjerskiego- Anny Dudek"
                        class="hero__img-main">
                </div>

                <!-- <div class="hero__img">
                    
                    <img src="../dist/img/heroImg.jpeg" alt="Zdjęcie właściceli salonu fryzjerskiego- Anny Dudek"
