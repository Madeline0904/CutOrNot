                        </div> -->
                        <div class="hero__button-box-two">
                            <a
                                href="https://booksy.com/pl-pl/199021_cut-or-not-pracownia-fryzjerska-anna-dudek_fryzjer_10953_zaczernie#ba_s=seo"><button
                                    class="hero__button-box-two-signup"><span class="signup-span">Zarezerwuj
                                        termin</span> </button></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="hero-arrow">
            <a href="#portfolio"><i class="fa-solid fa-chevron-down bounce-top"></i></a>
        </div>
    </section>

    <section class="portfolio" id="portfolio">
        <h2 class="section-title__main second-section">portfolio</h2>
        <div class="wrapper">

            <div class="cards-box">
                <div class="cards">
                    <div class="cards__card">
                        <div class="cards__card-after"></div>
                        <div class="cards__card-before"></div>
                    </div>
                    <div class="cards__card two">
                        <div class="cards__card-after after-two-img"></div>
                        <div class="cards__card-before before-two-img"></div>
                    </div>
                    <div class="cards__card three">
                        <div class="cards__card-after after-three-img"></div>
                        <div class="cards__card-before before-three-img"></div>
                    </div>
                    <div class="cards__card four">
                        <div class="cards__card-after after-four-img"></div>
                        <div class="cards__card-before before-four-img"></div>
                    </div>
                    <div class="cards__card five">
                        <div class="cards__card-after after-five-img"></div>
                        <div class="cards__card-before before-five-img"></div>
                    </div>
                    <div class="cards__card six">
                        <div class="cards__card-after after-six-img"></div>
                        <div class="cards__card-before before-six-img"></div>
                    </div>

                </div>
            </div>
            <a href="https://www.instagram.com/cut_or_not_anna_dudek/" target="_blank"><button
                    class="section-btn">Zobacz więcej!</button></a>



        </div>
    </section>
