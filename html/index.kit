       <!-- Slider main container -->
<!-- Slider main container -->
<div class="swiper">
    <!-- Additional required wrapper -->
    <div class="swiper-wrapper">
      <!-- Slides -->
      <div class="swiper-slide one">
        <i class="fa-solid fa-quote-right quote"></i>
        <div class="swiper-slide-box">
            
            <p>Bardzo polecam!
                Jestem zachwycona efektami koloryzacji i strzyżenia. Pełen profesjonalizm. Wszystko
                wykonywane z ogromną dokładnością. Od samego początku czułam, że jestem w najlepszych rękach
                i się nie myliłam. Moje włosy znów wyglądają pięknie i zdrowo, nie mogę się doczekać
                kolejnych wizyt ❤️</p>
                <strong>Kinga Kołodziej</strong>
        </div>
       
      </div>
      <div class="swiper-slide two">Slide 2</div>
      <div class="swiper-slide three">Slide 3</div>
      
    </div>
    <!-- If we need pagination -->
    <div class="swiper-pagination"></div>
  
    <!-- If we need navigation buttons -->
    <div class="swiper-button-prev"></div>
    <div class="swiper-button-next"></div>
  
    <!-- If we need scrollbar -->
    <div class="swiper-scrollbar"></div>
  </div>

    </section>


    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
  <script>  const swiper = new Swiper('.swiper', {
    // Optional parameters
    effect: "cube",
      grabCursor: true,
      cubeEffect: {
        shadow: true,
        slideShadows: true,
        shadowOffset: 20,
        shadowScale: 0.94,
      },
  
    // If we need pagination
    pagination: {
      el: '.swiper-pagination',
    },
  
    // Navigation arrows
    navigation: {
      nextEl: '.swiper-button-next',
      prevEl: '.swiper-button-prev',
    },
  
    // And if we need scrollbar
    scrollbar: {
      el: '.swiper-scrollbar',
    },
  });</script>
    <script src="dist/js/main.min.js"></script>


