                </div> -->
                <div class="hero__text-box">
                    <h1 class="hero__title">Anna<span>Dudek</span>
                    </h1>
                    <h2 class="hero__title-cd">Pracownia Fryzjerska</h2>
                    <img src="dist/img/logo_czarne tlo.png" alt="logo firmy- cut or not" class="hero__title-img">
                    <p class="hero__title-cd-name">Cut OR Not</p>

                    <div class="hero__button-box">
                        <!-- <div class="hero__button-box-one"> -->
                        <!-- <button class="hero__button-box-one-aboutme"><span class="aboutme-span"> o
                                    mnie</span></button>
