    <section class="section-offer"> 
    <!--@include 'nav.kit'-->    
  
    <div class="wrapper">
 <div class="section-title">
    <h1 class="section-title__main">oferta</h1>
    <div class="section-title__underline"></div>
 </div>
    <div class="offer">
        <div class=" offer__card offer__card--one">
            <div class="offer__card-bg">
               
